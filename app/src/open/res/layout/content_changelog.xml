<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/changelog_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/changelog_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="24dp">

        <!-- ============== 版本 1.1 模块 ============== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 头部：版本号 + 日期 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="版本 1.1"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:tag="date"
                    android:text="2026-04-18"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- 新增 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新增"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  笔记详情“分享”功能：可选文本或图片两种方式分享；图片支持多种内置背景模板、本地导入背景"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  分享背景模板栏：导入的本地图以“本地N”形式持久保存，缩略图右上角小叉号可一键移除"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  设置页“储存位置”切换功能：内置/外部，切换时自动迁移已有小说与分享背景"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  系统栏全透明：非阅读页采用 Edge-to-Edge，内容延伸到屏幕边缘；阅读页采用 Immersive Mode，默认隐藏菜单栏"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  “主题大一统”：日间 / 护眼 / 夜间一键切换，所有界面同步换色；主页切换时背景平滑过渡"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  主页设置“我的书架”与“所有笔记”两个分区"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  添加设置界面，功能尚未完善"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <!-- 修复 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="修复"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  从笔记详情进入小说，返回时回到笔记详情，而不是直接退到书架"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  打开小说时不再出现“白色 → 主题色”的闪烁"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  屏蔽系统主题颜色"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  修复文本的选中与拖动问题"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  高亮与笔记合二为一，保证同一段原文不再重复记录"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- 模块间细线分隔 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:tag="divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

        <!-- ============== 版本 1.2 模块 ============== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 头部：版本号 + 日期 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="版本 1.2"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:tag="date"
                    android:text="2026-04-29"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- 新增 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新增"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  书架每本书、所有笔记每个模块改为独立气泡框"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  以蓝色为主色的时代一去不复返"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  减小行间距，增大可用高度，使阅读段落更紧凑"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <!-- 修复 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="修复"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  大量修复布局瑕疵"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  使沉浸模式能适配全面屏"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  修复了导入成功后点击“开始阅读”时的崩溃问题"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•  修复了横竖屏切换时的崩溃问题"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- 模块间细线分隔（当有新版本时在此插入）
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:tag="divider"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />
        -->

    </LinearLayout>
</ScrollView>
