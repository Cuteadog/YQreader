<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/share_sheet_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="8dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tv_share_sheet_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:text="@string/share_title"
        android:textColor="#333333"
        android:textSize="14sp"
        android:textStyle="bold" />

    <View
        android:id="@+id/share_sheet_divider_top"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#E0E0E0" />

    <TextView
        android:id="@+id/btn_share_as_text"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="@string/share_as_text"
        android:textColor="#333333"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/btn_share_as_image"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="@string/share_as_image"
        android:textColor="#333333"
        android:textSize="15sp" />

    <View
        android:id="@+id/share_sheet_divider_bottom"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="#F5F5F5" />

    <TextView
        android:id="@+id/btn_share_cancel"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="@string/cancel"
        android:textColor="#757575"
        android:textSize="15sp" />

</LinearLayout>
